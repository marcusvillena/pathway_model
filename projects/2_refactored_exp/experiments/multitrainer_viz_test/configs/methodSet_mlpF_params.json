{
    "model": {
        "dataset": "GraphDataset",
        "embed_dim": 128,
        "head_dim": null,
        "num_heads": 4,
        "method": "set",
        "norm_class": "LogCounts",
        "encoder_class": "Linear",
        "pooling_class": "MultiheadSetPooling",
        "mlp": false,
        "variational": true,
        "hidden_dims": 1,
        "act_fn": "ReLU",
        "norm_fn": "layer",
        "dropout": 0.3,
        "end_fn": false,
        "norm_kwargs": {
            "libnorm": true,
            "znorm": true,
            "learnable": true
        },
        "pooling_kwargs": {
            "aggregate": "concat"
        }
    },
    "trainer": {
        "ae": {
            "lr": 0.001,
            "pos_keys": null,
            "kw_keys": {
                "x": "x",
                "x_pred": "x_pred",
                "theta": "theta",
                "z_mu_ae": "z_mu_ae",
                "z_logvar_ae": "z_logvar_ae",
                "batch_size": "batch_size",
                "num_nodes": "num_nodes"
            },
            "loss_class": "MultiLoss",
            "loss_kwargs": {
                "loss_classes": [
                    "NBLoss",
                    "KLDLoss"
                ],
                "loss_weights": [
                    1.0,
                    0.0001
                ],
                "loss_inputs": [
                    {
                        "x": "x",
                        "mu": "x_pred",
                        "theta": "theta"
                    },
                    {
                        "mu": "z_mu_ae",
                        "logvar": "z_logvar_ae"
                    }
                ]
            },
            "optim_class": "Adam",
            "optim_kwargs": null,
            "early_stop": true,
            "stop_metric": "mae",
            "stop_kwargs": null,
            "metric_keys": {
                "pred": "x_pred",
                "target": "x"
            },
            "trainer_norm_class": "LogCounts",
            "trainer_norm_kwargs": {}
        },
        "cl": {
            "lr": 0.001,
            "pos_keys": null,
            "kw_keys": {
                "input": "y_logits",
                "target": "y",
                "batch_size": "batch_size",
                "num_nodes": "num_nodes"
            },
            "loss_class": "CrossEntropyLoss",
            "loss_kwargs": {
                "label_smoothing": 0.1
            },
            "optim_class": "Adam",
            "optim_kwargs": null,
            "early_stop": true,
            "stop_metric": "accuracy",
            "stop_kwargs": {
                "mode": "max"
            },
            "metric_keys": {
                "pred": "input",
                "target": "target"
            },
            "weight_method": "balanced"
        }
    }
}